DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/app
AUTH_SECRET=change-me-in-production
# Orígenes permitidos para CORS (JSON array). En producción pon la URL de tu frontend.
CORS_ORIGINS=["http://localhost:3000"]
# Poner a true en el servidor web cuando el scheduler corra en worker.py separado.
DISABLE_SCHEDULER=false
SHOPIFY_SYNC_ENABLED=true
SHOPIFY_SYNC_INTERVAL_MINUTES=5
SHOPIFY_SYNC_MAX_ORDERS=5000
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_SSL_VERIFY=true
SHOPIFY_SSL_CAFILE=
